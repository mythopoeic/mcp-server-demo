# LLM provider configuration for the extract_orders stretch tool.
# Copy to .env (gitignored) and adjust for your machine.
#
# SECRETS: AWS credentials are resolved from the standard AWS credential chain
# (~/.aws/credentials, SSO, or instance role) — do NOT put AWS keys in this file
# or in .env. Only non-secret config (region, model ids, provider selection) lives here.

# Which provider the stretch tool uses: "bedrock" (primary) or "anthropic" (fallback).
LLM_PROVIDER=bedrock

# --- Bedrock (primary) -------------------------------------------------------
# Region is REQUIRED and must match where your Anthropic model access is enabled.
# We use the classic AnthropicBedrock (bedrock-runtime InvokeModel) client so the
# calls show up in Bedrock model-invocation logging + CloudWatch metrics. On-demand
# Haiku 4.5 needs a cross-region INFERENCE PROFILE id (the "us." / "global." prefix);
# the bare foundation-model id 400s with "on-demand throughput isn't supported".
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
# Swap live to demonstrate the abstraction: us.anthropic.claude-opus-4-... (the
# matching Opus inference-profile id from `aws bedrock list-inference-profiles`).

# --- Anthropic-direct (fallback) ---------------------------------------------
# Only needed if LLM_PROVIDER=anthropic, or if you want the fallback to fire.
ANTHROPIC_MODEL_ID=claude-haiku-4-5
# ANTHROPIC_API_KEY=   # set via your shell / secret manager — never commit
